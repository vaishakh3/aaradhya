# Optional read-only fallback. The admin panel uses the service-account settings below.
GOOGLE_SHEETS_CSV_URL=

# Admin sign-in. Use a long random SESSION_SECRET.
ADMIN_USERNAME=aaradhya-admin
ADMIN_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-at-least-32-random-characters

# Google Sheets read/write access.
# Create a spreadsheet, copy its ID from the URL, and share it with the service-account email as an editor.
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Signed Cloudinary image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=aaradhya/products
